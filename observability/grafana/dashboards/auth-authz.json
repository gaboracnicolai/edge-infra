  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "JWKS refresh failures (1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum(increase(jwks_refresh_total{result=\"failure\"}[1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "timeseries",
      "title": "Auth requests/s by result",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 2,
      "targets": [{"expr": "sum by (result) (rate(auth_requests_total[5m]))", "legendFormat": "{{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "timeseries",
      "title": "Denial ratio",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 3,
      "targets": [{"expr": "edge:auth_denial_ratio:rate5m", "legendFormat": "denial ratio", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "timeseries",
      "title": "JWT validation P99 latency",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 4,
      "targets": [{"expr": "histogram_quantile(0.99, rate(jwt_validation_duration_seconds_bucket[5m]))", "legendFormat": "p99", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "logs",
      "title": "auth-service warnings",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "id": 5,
      "targets": [{"expr": "{app=\"auth-service\"} | json | level=\"warn\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": false, "showLabels": false, "showCommonLabels": false, "enableLogDetails": true, "sortOrder": "Descending"}
    }
  ],
