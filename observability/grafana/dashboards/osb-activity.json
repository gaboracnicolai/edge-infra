{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "NATS consumer pending",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "max(nats_consumer_num_pending{consumer=\"osb-workers\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 50}, {"color": "red", "value": 100}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "timeseries",
      "title": "Provision requests/s by operation",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 2,
      "targets": [{"expr": "sum by (operation) (rate(osb_requests_total[5m]))", "legendFormat": "{{operation}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "timeseries",
      "title": "NAK ratio",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 3,
      "targets": [{"expr": "edge:osb_nak_ratio:rate5m", "legendFormat": "nak ratio", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "timeseries",
      "title": "Webhook delivery success/failure",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 4,
      "targets": [{"expr": "sum by (result) (rate(osb_webhook_deliveries_total[5m]))", "legendFormat": "{{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "type": "logs",
      "title": "OSB non-info logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "id": 5,
      "targets": [{"expr": "{app=\"edge-osb\"} | json | level!=\"info\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": false, "showLabels": false, "showCommonLabels": false, "enableLogDetails": true, "sortOrder": "Descending"}
    },
    {
      "type": "table",
      "title": "Recent provision requests",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 30},
      "id": 6,
      "targets": [{"expr": "{app=\"edge-osb\"} | json | event=\"provision queued\"", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["edge", "osb"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
